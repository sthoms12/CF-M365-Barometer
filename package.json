{
  "name": "m365-barometer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "dev": "npm run build && wrangler dev --local --port 5173 --test-scheduled",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && wrangler deploy",
    "types": "wrangler types",
    "check": "npm run types && tsc -b --pretty false && vitest run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.8.5",
    "jose": "^6.1.3",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260606.1",
    "@types/node": "22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "^5.8.3",
    "vite": "6.4.3",
    "vitest": "4.1.8",
    "wrangler": "4.86.0"
  },
  "overrides": {
    "ws": "8.20.1"
  }
}
